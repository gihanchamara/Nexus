    %% ═══════════════════════════════════════════════════════════════════════
    %% DATA FLOW CONNECTIONS
    %% ═══════════════════════════════════════════════════════════════════════

    %% External → Ingestion
    IBKR_GW  --> MKT_ING
    IBKR_GW  --> OPT_ING
    IBKR_GW  --> HIST
    NEWS_API --> NEWS_ING
    ALT_DATA --> NEWS_ING
    ALT_DATA --> OPT_FLOW
    MACRO_SRC --> NEWS_ING

    %% Ingestion → Event Bus
    MKT_ING  --> BUS_MKT
    OPT_ING  --> BUS_MKT
    NEWS_ING --> BUS_MKT

    %% Ingestion → Persist (direct write for bulk data)
    HIST     --> TSDB_DB
    MKT_ING  --> TSDB_DB
    OPT_ING  --> TSDB_DB

    %% Bus → AI Engine
    BUS_MKT  --> REGIME
    BUS_MKT  --> IV_SURF
    BUS_MKT  --> FEAT
    BUS_MKT  --> SENT

    %% AI internal
    IV_SURF  --> IV_RANK
    IV_RANK  --> STRAT_SEL
    REGIME   --> STRAT_SEL
    OPT_FLOW --> FEAT
    SENT     --> FEAT
    FEAT     --> REGIME
    BUS_SIG  --> SIG_ENS

    %% AI → Bus
    REGIME   --> BUS_AI
    IV_RANK  --> BUS_AI
    SENT     --> BUS_AI
    FEAT     --> BUS_AI
    SIG_ENS  --> BUS_AI
    PORT_OPT --> BUS_AI

    %% StrategySelector → strategy.activation
    STRAT_SEL --> BUS_SIG
    PORT_OPT  --> PORT_MGR

    %% AI → Persist
    PORT_OPT --> MODEL_STORE

    %% Bus → Strategy (activation + market data)
    BUS_MKT  --> STRAT_REG
    BUS_SIG  --> STRAT_REG

    %% Strategy → Bus
    STRAT_REG --> BUS_SIG
    EXPIRY    --> BUS_SIG
    PORT_MGR  --> BUS_SIG

    %% OMS can read ai.signal instead of strategy.signal (ensemble mode)
    BUS_AI   --> SIG_ROUTE

    %% Bus → Risk
    BUS_SIG --> GREEKS_MON
    BUS_SIG --> POS_LIM
    BUS_ORD --> GREEKS_MON
    BUS_ORD --> DD_MON

    %% Risk internal
    GREEKS_MON --> PORT_GLIM
    GREEKS_MON --> DELTA_H

    %% Risk → OMS
    PORT_GLIM --> SIG_ROUTE
    POS_LIM   --> SIG_ROUTE
    DD_MON    --> SIG_ROUTE
    KILL      --> SIG_ROUTE
    DELTA_H   --> SIG_ROUTE

    %% OMS flow
    SIG_ROUTE  --> POS_SIZE
    POS_SIZE   --> ORD_BUILD
    ORD_BUILD  --> PAPER_ENG
    ORD_BUILD  --> LIVE_EXEC

    %% OMS → Bus
    PAPER_ENG  --> BUS_ORD
    LIVE_EXEC  --> BUS_ORD

    %% Backtest flow (reads history, uses same strategy + risk code)
    TSDB_DB    --> BT_REPLAY
    BT_REPLAY  --> OPT_PRICE
    OPT_PRICE  --> BT_FILL
    BT_FILL    --> BT_PERF
    BT_PERF    --> WFO
    WFO        --> MODEL_STORE
    BT_PERF    --> MYSQL_DB

    %% Persistence writes
    BUS_ORD --> MYSQL_DB
    BUS_SIG --> MYSQL_DB

    %% Observability
    BUS_SYS --> TEL_AGG
    BUS_ORD --> TEL_AGG
    BUS_SIG --> TEL_AGG
    TEL_AGG --> DASH
    TEL_AGG --> ALERT
    ALERT   --> BUS_SYS

