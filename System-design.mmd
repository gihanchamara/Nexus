    %% ── AI ENGINE ───────────────────────────────────────────────────────────
    subgraph AI["🤖  AI / Analytics Engine  ·  Platform differentiator — AI drives strategy selection, not just signals"]

        subgraph AI_MARKET["Market Intelligence"]
            REGIME["Market Regime Detector (regime.py)
            ──────────────────────
            States: BULL_TREND|BEAR_TREND|SIDEWAYS_CHOP|HIGH_VOL|CRISIS
            Tier 1: Rule-based (always active; confidence 0.60)
            Tier 2: GaussianHMM via hmmlearn (loaded from disk)
            Tier 3: XGBoost companion classifier (semi-supervised)
            Graceful fallback if hmmlearn/model absent
            Publishes → ai.regime"]

            IV_SURF["IV Surface Modeler
            ──────────────────────
            Builds full implied vol surface per symbol
            Term structure: contango vs backwardation
            Vol skew: put skew / call skew / smile
            Parametrisation: SVI / SABR
            Snapshots stored → TimescaleDB
            Updates: on each options chain pull"]

            IV_RANK["IV Rank & Percentile Engine
            ──────────────────────
            IVR = (IV_now - IV_52wLow) / (IV_52wHigh - IV_52wLow)
            IVP = percentile of IV_now in 1Y distribution
            ─────────────────────────────────────────
            IVR > 50  →  favour SELLING options
                          Iron Condor · CSP · Covered Call
            IVR < 30  →  favour BUYING options
                          Straddle · Long Call · Vertical Spread
            ⚡ Key gate for options strategy selection"]

            OPT_FLOW["Options Flow Analyzer
            ──────────────────────
            Unusual OI sweeps & large block trades
            Put/Call OI ratio trends per symbol
            Dark pool print pattern matching
            Whale position tracking (size + strike)
            Smart money signal score: 0–1
            Feeds → Feature Store"]
        end

        subgraph AI_SIG["Signal Generation"]
            SENT["Sentiment Analyzer (sentiment.py)
            ──────────────────────
            Claude claude-haiku-4-5 (NEXUS_ANTHROPIC_API_KEY)
            Structured JSON output: score · confidence · catalyst
            Keyword fallback if API key absent
            Rate-limited: 1 call/symbol/minute
            confidence_multiplier() → 0.5–1.5 applied in OMS
            Publishes → ai.sentiment"]

            FEAT["Feature Store (features.py)
            ──────────────────────
            Pure Python ring buffers (no pandas in hot path)
            RSI (Wilder) · MACD (EMA12-26) · Bollinger %B
            ATR (Wilder) · Rolling HV 20/60 · Momentum 5/20/60
            Volume ratio · log returns
            FeatureSnapshot.to_vector() → 11-element ML input
            Publishes → ai.features"]

            SIG_ENS["Signal Ensemble (signal_ensemble.py)
            ──────────────────────
            Reads: strategy.signal (XREADGROUP consumer group)
            Sharpe-weighted votes within 5-second window
            Decisive threshold: dominant ≥ 55% of total weight
            Conflict suppression (BUY + SELL → drop)
            Publishes → ai.signal"]
        end

        subgraph AI_META["Meta-AI Layer  ·  AI decides WHAT to trade, not just direction"]
            STRAT_SEL["Strategy Selector AI (strategy_selector.py)
            ──────────────────────
            Priority 1: CRISIS → deactivate ALL risk-on
            Priority 2: Greeks guard (delta>400 or vega>4000)
            Priority 3: Regime × IVR matrix:
              SIDEWAYS + IVR≥50  →  Iron Condor / Strangle
              BULL     + IVR≥50  →  Covered Call / CSP
              BULL     + IVR<50  →  MA Crossover / Bull Spread
              BEAR     + IVR≥50  →  Bear Spread / Protective Put
              BEAR     + IVR<50  →  Long Put / Bear Spread
              HIGH_VOL + IVR≥60  →  Iron Condor / Short Strangle
            Publishes → strategy.activation"]

            PORT_OPT["Portfolio Optimizer (portfolio_optimizer.py)
            ──────────────────────
            Methods: half-Kelly · MV (scipy SLSQP) · risk-parity · equal
            Max 50% concentration cap; floor 5%
            risk-parity: w_i ∝ 1/σ_i (uncorrelated ERC)
            Publishes → ai.allocation"]
        end
    end

