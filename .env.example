# ─── Copy this file to .env and fill in values ──────────────────────────────
# NEVER commit .env to version control

# ─── PostgreSQL (orders, positions, strategy config, audit) ──────────────────
POSTGRES_ROOT_PASSWORD=change_me_root
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_me_nexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexus

# ─── TimescaleDB (OHLCV bars, tick data) ─────────────────────────────────────
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=change_me_ts
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_DB=nexus_ts

# ─── Redis Streams ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis
REDIS_DB=0

# ─── IBKR Connection ─────────────────────────────────────────────────────────
# Paper trading: TWS port 7497, IB Gateway port 4002
# Live trading:  TWS port 7496, IB Gateway port 4001
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=             # Your paper/live account ID (e.g. DU1234567)

# ─── Trading Mode ────────────────────────────────────────────────────────────
# PAPER | LIVE  — PAPER is always the safe default
NEXUS_TRADING_MODE=PAPER
# Set to 1 to immediately halt all live order submission
NEXUS_KILL_SWITCH=0

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_jwt_secret_min_32_chars_long

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── SSH MCP Server ──────────────────────────────────────────────────────────
# Remote server connection parameters (no password here — stored in macOS Keychain)
SSH_HOST=your.server.ip.or.hostname
SSH_PORT=22
SSH_USER=ubuntu
# Keychain lookup keys — must match what you used in: keyring set <service> <username>
SSH_KEYCHAIN_SERVICE=nexus-ssh
SSH_KEYCHAIN_USERNAME=nexus-deploy
# Directory for daily-rotating ssh_mcp.log (leave unset to log to stdout only)
SSH_LOG_DIR=logs/ssh
